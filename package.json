{
  "name": "@curaos/tasks-sdk",
  "description": "CuraOS @curaos/tasks-sdk - typed REST client + event wire-types generated from tasks-service's TypeSpec + AsyncAPI contracts (ADR-0103 TypeSpec-first). Zero hand-written transport code.",
  "version": "0.1.0",
  "dependencies": {
    "@hey-api/client-fetch": "0.13.1"
  },
  "devDependencies": {
    "@asyncapi/parser": "3.6.0",
    "@curaos/tsconfig": "workspace:*",
    "@hey-api/openapi-ts": "0.98.1",
    "@types/node": "22.19.19",
    "json-schema-to-typescript": "15.0.4",
    "typescript": "5.9.3"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "main": "./dist/index.js",
  "packageManager": "bun@1.3.14",
  "private": false,
  "publishConfig": {
    "access": "restricted",
    "registry": "http://localhost:4873"
  },
  "scripts": {
    "build": "tsc",
    "ci": "bun run lint && bun run typecheck && bun run test && bun run build",
    "generate": "bun scripts/generate.mjs",
    "lint": "oxlint .",
    "publish-smoke": "node ../../../scripts/sdk-package-publishing.mjs --package tasks",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "typecheck": "tsc --noEmit"
  },
  "type": "commonjs",
  "types": "./dist/index.d.ts"
}
